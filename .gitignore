# =============================================================================
# Credentials & Secrets — never commit
# =============================================================================
credentials/
secrets/
service-account.json
*.pem
*.key
*.p12
*.pfx

# =============================================================================
# Environment variables
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.pytype/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# =============================================================================
# Data files (large binaries — distribute separately)
# =============================================================================
data/
*.duckdb
*.duckdb.wal
*.parquet
*.csv
*.xlsx
*.xls

# =============================================================================
# Logs & pipeline run artifacts
# =============================================================================
logs/
*.log

# =============================================================================
# Bruin pipeline
# =============================================================================
.bruin.yml

# =============================================================================
# Jupyter / IPython
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Streamlit
# =============================================================================
.streamlit/secrets.toml

# =============================================================================
# Docker
# =============================================================================
.dockerignore

# =============================================================================
# OS-generated files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# IDEs & editors
# =============================================================================
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# =============================================================================
# Terraform (kept in case infra is added later)
# =============================================================================
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/.terraform.lock.hcl
terraform/terraform.tfvars

logs/runs
logs/*.log